---
interface Props {
  eyebrow?: string;
  title: string;
  text?: string;
}

const {
  eyebrow = 'Раздел',
  title,
  text = 'Временная секция-заглушка для сборки нового лендинга.'
} = Astro.props;
---
<section class="section">
  <div class="container">
    <div class="stub">
      <p class="stub__eyebrow">{eyebrow}</p>
      <h2 class="stub__title">{title}</h2>
      <p class="stub__text">{text}</p>
    </div>
  </div>
</section>
