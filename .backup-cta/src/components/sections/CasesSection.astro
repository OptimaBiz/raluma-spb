---
const cases = [
  {
    id: 'case-terrasy',
    badge: 'Слайд',
    type: 'Терраса частного дома',
    location: 'Сестрорецк',
    title: 'Терраса с выходом в сад',
    area: '22 м²',
    note: 'Нижнеопорная система без нагрузки на кровлю, монтаж за 2 дня, цвет RAL 7016.',
    image: '/images/gallery/terrasy/slide-terrasy-1.jpg',
    imageAlt: 'Терраса с панорамным безрамным остеклением, Сестрорецк',
  },
  {
    id: 'case-veranda',
    badge: 'Слайд',
    type: 'Веранда загородного дома',
    location: 'Всеволожский район',
    title: 'Веранда под ключ',
    area: '28 м²',
    note: 'Нестандартная ширина проёма, подбор конфигурации на замере, цвет под фасад.',
    image: '/images/gallery/verandy/slide-verandy-1.jpg',
    imageAlt: 'Веранда с безрамным остеклением, Всеволожск',
  },
  {
    id: 'case-restaurant',
    badge: 'Лифт',
    type: 'Ресторан',
    location: 'Пушкин',
    title: 'Летняя веранда ресторана',
    area: '40 м²',
    note: 'Коммерческий объект с высокой интенсивностью использования, сезонная эксплуатация.',
    image: '/images/gallery/lift/lift-4.jpg',
    imageAlt: 'Остекление ресторанной веранды системой Лифт, Пушкин',
  },
];
---

<section class="cases" id="cases" aria-labelledby="cases-title">
  <div class="cases__wrap">

    <div class="cases__head">
      <p class="cases__eyebrow">Реализованные проекты</p>
      <h2 class="cases__title" id="cases-title">Работы в Санкт-Петербурге и области</h2>
      <p class="cases__lead">
        Реальные объекты с указанием системы, площади и задачи, которую решала конструкция.
      </p>
    </div>

    <div class="cases__grid">
      {cases.map((c) => (
        <article class="case-card">
          <div class="case-card__photo">
            <img
              class="case-card__img"
              src={c.image}
              alt={c.imageAlt}
              loading="lazy"
              decoding="async"
            />
            <span class="case-card__badge">{c.badge}</span>
          </div>
          <div class="case-card__body">
            <div class="case-card__meta">
              <span class="case-card__type">{c.type}</span>
              <span class="case-card__sep" aria-hidden="true">·</span>
              <span class="case-card__loc">{c.location}</span>
            </div>
            <h3 class="case-card__name">{c.title}</h3>
            <p class="case-card__area">{c.area}</p>
            <p class="case-card__note">{c.note}</p>
          </div>
        </article>
      ))}
    </div>

    <div class="cases__foot">
      <a class="cases__cta" href="#lead-form">Обсудить ваш проект</a>
    </div>

  </div>
</section>

<style>
  .cases {
    background: #ffffff;
    color: #111111;
  }

  .cases__wrap {
    max-width: 1280px;
    margin: 0 auto;
    padding: clamp(72px, 8vw, 120px) 24px;
  }

  /* ── Head ── */
  .cases__head {
    max-width: 820px;
    margin-bottom: clamp(32px, 4vw, 52px);
  }

  .cases__eyebrow {
    margin: 0 0 14px;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: #e44336;
  }

  .cases__title {
    margin: 0;
    font-size: clamp(34px, 4.5vw, 56px);
    line-height: 0.97;
    letter-spacing: -0.04em;
    font-weight: 700;
    text-wrap: balance;
  }

  .cases__lead {
    margin: 18px 0 0;
    font-size: clamp(16px, 1.35vw, 19px);
    line-height: 1.68;
    color: #5f6773;
    max-width: 640px;
  }

  /* ── Grid ── */
  .cases__grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 20px;
  }

  /* ── Card ── */
  .case-card {
    display: flex;
    flex-direction: column;
    border-radius: 24px;
    border: 1px solid rgba(17, 17, 17, 0.08);
    background: #ffffff;
    overflow: hidden;
    box-shadow:
      0 1px 0 rgba(17, 17, 17, 0.04),
      0 20px 52px rgba(17, 17, 17, 0.07);
    transition:
      transform 0.28s ease,
      box-shadow 0.28s ease,
      border-color 0.28s ease;
  }

  .case-card:hover {
    transform: translateY(-4px);
    border-color: rgba(228, 67, 54, 0.16);
    box-shadow:
      0 1px 0 rgba(17, 17, 17, 0.05),
      0 28px 68px rgba(17, 17, 17, 0.11);
  }

  .case-card__photo {
    position: relative;
    aspect-ratio: 4 / 3;
    overflow: hidden;
    background: #e8e6e3;
  }

  .case-card__img {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.5s ease;
  }

  .case-card:hover .case-card__img {
    transform: scale(1.04);
  }

  .case-card__badge {
    position: absolute;
    top: 14px;
    left: 14px;
    padding: 5px 11px;
    border-radius: 999px;
    background: rgba(17, 17, 17, 0.68);
    backdrop-filter: blur(10px);
    border: 1px solid rgba(255, 255, 255, 0.14);
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.10em;
    color: #ffffff;
    text-transform: uppercase;
  }

  .case-card__body {
    padding: 22px 22px 24px;
    flex: 1;
    display: flex;
    flex-direction: column;
  }

  .case-card__meta {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 5px;
    margin-bottom: 10px;
    font-size: 13px;
    color: #7a818c;
    line-height: 1.3;
  }

  .case-card__type {
    font-weight: 500;
  }

  .case-card__sep {
    opacity: 0.45;
  }

  .case-card__name {
    margin: 0;
    font-size: clamp(20px, 1.8vw, 26px);
    line-height: 1.1;
    letter-spacing: -0.025em;
    font-weight: 700;
    color: #111111;
    text-wrap: balance;
  }

  .case-card__area {
    margin: 10px 0 0;
    font-size: 13px;
    font-weight: 700;
    letter-spacing: 0.04em;
    color: #e44336;
  }

  .case-card__note {
    margin: 10px 0 0;
    font-size: 14px;
    line-height: 1.65;
    color: #606874;
    flex: 1;
  }

  /* ── Footer CTA ── */
  .cases__foot {
    display: flex;
    justify-content: center;
    margin-top: clamp(32px, 4vw, 48px);
  }

  .cases__cta {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 52px;
    padding: 0 28px;
    border-radius: 999px;
    background: #111111;
    color: #ffffff;
    font-size: 15px;
    font-weight: 700;
    text-decoration: none;
    transition:
      transform 0.24s ease,
      background 0.24s ease,
      box-shadow 0.24s ease;
  }

  .cases__cta:hover {
    transform: translateY(-2px);
    background: #1b1b1b;
    box-shadow: 0 16px 34px rgba(17, 17, 17, 0.18);
  }

  /* ── Responsive ── */
  @media (max-width: 900px) {
    .cases__grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 600px) {
    .cases__wrap {
      padding: 56px 16px;
    }

    .cases__grid {
      grid-template-columns: 1fr;
      gap: 16px;
    }

    .case-card {
      border-radius: 20px;
    }

    .case-card__photo {
      aspect-ratio: 16 / 9;
    }

    .case-card__body {
      padding: 18px 18px 20px;
    }

    .case-card__name {
      font-size: 21px;
    }
  }
</style>
