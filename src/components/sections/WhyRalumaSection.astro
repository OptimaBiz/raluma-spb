---
const proofCards = [
  {
    id: 'experience',
    type: 'featured',
    label: 'Нам доверяют',
    title: '12 лет опыта и 4000+ реализованных проектов',
    text:
      'Решения Raluma проверены на большом количестве частных и коммерческих объектов. Это отработанная система с понятной технологией, монтажом и эксплуатацией.'
  },
  {
    id: 'production',
    type: 'standard',
    label: 'Производство',
    title: 'Собственное производство',
    text:
      'Контролируем качество, сроки и монтаж.'
  },
  {
    id: 'stock',
    type: 'standard',
    label: 'Поставки',
    title: 'Комплектующие всегда в наличии',
    text:
      'Снижаем риск задержек по поставке и делаем реализацию проекта более предсказуемой.'
  },
  {
    id: 'support',
    type: 'standard',
    label: 'Конструкция',
    title: 'Нижнеопорные системы',
    text:
      'Подходят для готовых объектов, где важно не перегружать кровлю и существующие конструкции.'
  },
  {
    id: 'anod',
    type: 'standard',
    label: 'Защита',
    title: 'Технология ANOD+',
    text:
      'Дополнительная защита алюминия от коррозии, износа и механических воздействий в реальной эксплуатации.'
  },
];
---

<section class="why-raluma" id="why-raluma" aria-labelledby="why-raluma-title">
  <div class="why-raluma__container">
    <div class="why-raluma__intro">
      <p class="why-raluma__eyebrow">Почему Raluma</p>
      <h2 class="why-raluma__title" id="why-raluma-title">
        Системы Raluma не подведут вас
      </h2>
      <p class="why-raluma__lead">
        Производство, инженерный подход, комплектующие в наличии и решения, рассчитанные
        на реальную эксплуатацию, а не только на красивую картинку в каталоге.
      </p>
    </div>

    <div class="why-raluma__grid">
      {proofCards.map((card, index) => (
        <article class={`proof-card proof-card--${card.type} proof-card--${card.id}`}>
          <div class="proof-card__head">
            <span class="proof-card__index">{String(index + 1).padStart(2, '0')}</span>
            <p class="proof-card__label">{card.label}</p>
          </div>

          <h3 class="proof-card__title">{card.title}</h3>
          <p class="proof-card__text">{card.text}</p>
        </article>
      ))}
    </div>

    <div class="why-raluma__footer">
      <div class="why-raluma__footer-copy">
        <p class="why-raluma__footer-title">
          Подбираем решение не по шаблону, а под конструкцию, сценарий использования и архитектуру объекта.
        </p>
        <p class="why-raluma__footer-text">
          Поэтому система выглядит уместно, работает стабильно и не создаёт проблем на этапе монтажа и эксплуатации.
        </p>
      </div>

      <a class="why-raluma__cta" href="#lead-form">
        Получить расчёт
      </a>
    </div>
  </div>
</section>

<style>
  .why-raluma {
    background:
      radial-gradient(circle at top left, rgba(228, 67, 54, 0.05), transparent 24%),
      linear-gradient(180deg, #f3f1ef 0%, #efedeb 100%);
    color: #111111;
    overflow: clip;
  }

  .why-raluma__container {
    max-width: 1280px;
    margin: 0 auto;
    padding: clamp(72px, 8vw, 128px) 24px;
  }

  .why-raluma__intro {
    max-width: 980px;
    margin: 0 auto 30px;
    text-align: center;
  }

  .why-raluma__eyebrow {
    margin: 0 0 14px;
    font-size: 12px;
    font-weight: 700;
    line-height: 1.2;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: #e44336;
  }

  .why-raluma__title {
    margin: 0 auto;
    max-width: 15ch;
    font-size: clamp(38px, 4.8vw, 60px);
    line-height: 0.96;
    letter-spacing: -0.045em;
    font-weight: 700;
    text-wrap: balance;
  }

  .why-raluma__lead {
    margin: 18px auto 0;
    max-width: 760px;
    font-size: clamp(17px, 1.45vw, 20px);
    line-height: 1.68;
    color: #5f6773;
    text-wrap: balance;
  }

  .why-raluma__grid {
    display: grid;
    grid-template-columns: repeat(12, minmax(0, 1fr));
    gap: 16px;
  }

  .proof-card {
    position: relative;
    min-width: 0;
    padding: 24px;
    border-radius: 28px;
    border: 1px solid rgba(17, 17, 17, 0.08);
    background: rgba(255, 255, 255, 0.82);
    box-shadow:
      0 1px 0 rgba(17, 17, 17, 0.04),
      0 20px 56px rgba(17, 17, 17, 0.06);
  }

  .proof-card::before {
    content: "";
    position: absolute;
    left: 0;
    top: 24px;
    bottom: 24px;
    width: 4px;
    border-radius: 0 999px 999px 0;
    background: rgba(228, 67, 54, 0.16);
  }

  .proof-card--featured {
    grid-column: span 5;
    padding: 30px;
    background:
      linear-gradient(180deg, rgba(255, 255, 255, 0.98) 0%, rgba(255, 249, 248, 0.96) 100%);
    border-color: rgba(228, 67, 54, 0.18);
    box-shadow:
      0 1px 0 rgba(17, 17, 17, 0.05),
      0 28px 68px rgba(17, 17, 17, 0.08),
      0 0 0 2px rgba(228, 67, 54, 0.08);
  }

  .proof-card--featured::before {
    width: 5px;
    background: linear-gradient(180deg, #ff6b5d 0%, #e44336 100%);
    box-shadow: 0 0 20px rgba(228, 67, 54, 0.2);
  }

  .proof-card--production {
    grid-column: span 3;
  }

  .proof-card--stock {
    grid-column: span 4;
  }

  .proof-card--support,
  .proof-card--anod,
  .proof-card--ral {
    grid-column: span 4;
  }

  .proof-card__head {
    display: flex;
    align-items: center;
    gap: 10px;
    margin-bottom: 18px;
  }

  .proof-card__index {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 34px;
    height: 34px;
    padding: 0 10px;
    border-radius: 999px;
    background: rgba(17, 17, 17, 0.05);
    font-size: 11px;
    line-height: 1;
    font-weight: 800;
    letter-spacing: 0.08em;
    color: #7a818c;
  }

  .proof-card--featured .proof-card__index {
    background: rgba(228, 67, 54, 0.10);
    color: #c63a2e;
  }

  .proof-card__label {
    margin: 0;
    font-size: 12px;
    line-height: 1.2;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: #e44336;
  }

  .proof-card__title {
    margin: 0;
    font-size: clamp(24px, 2.2vw, 34px);
    line-height: 1.02;
    letter-spacing: -0.035em;
    font-weight: 700;
    color: #111111;
    text-wrap: balance;
  }

  .proof-card--featured .proof-card__title {
    font-size: clamp(30px, 2.9vw, 42px);
    max-width: 11ch;
  }

  .proof-card__text {
    margin: 16px 0 0;
    font-size: 15px;
    line-height: 1.68;
    color: #5f6773;
  }

  .why-raluma__footer {
    margin-top: 18px;
    display: flex;
    gap: 18px;
    align-items: center;
    justify-content: space-between;
    padding: 22px 24px;
    border-radius: 28px;
    border: 1px solid rgba(17, 17, 17, 0.08);
    background: rgba(255, 255, 255, 0.76);
    box-shadow:
      0 1px 0 rgba(17, 17, 17, 0.04),
      0 16px 40px rgba(17, 17, 17, 0.05);
  }

  .why-raluma__footer-copy {
    max-width: 760px;
  }

  .why-raluma__footer-title {
    margin: 0;
    font-size: clamp(20px, 1.9vw, 28px);
    line-height: 1.18;
    letter-spacing: -0.03em;
    font-weight: 700;
    color: #111111;
  }

  .why-raluma__footer-text {
    margin: 10px 0 0;
    font-size: 15px;
    line-height: 1.64;
    color: #5f6773;
  }

  .why-raluma__cta {
    flex-shrink: 0;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 50px;
    padding: 0 20px;
    border-radius: 999px;
    background: #111111;
    color: #ffffff;
    font-size: 14px;
    line-height: 1;
    font-weight: 700;
    text-decoration: none;
    transition:
      transform 0.24s ease,
      background 0.24s ease,
      box-shadow 0.24s ease;
  }

  .why-raluma__cta:hover {
    transform: translateY(-2px);
    background: #1b1b1b;
    box-shadow: 0 16px 34px rgba(17, 17, 17, 0.16);
  }

  @media (max-width: 1120px) {
    .why-raluma__grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .proof-card--featured,
    .proof-card--production,
    .proof-card--stock,
    .proof-card--support,
    .proof-card--anod,
    .proof-card--ral {
      grid-column: span 1;
    }

    .proof-card--featured .proof-card__title {
      max-width: none;
    }

    .why-raluma__footer {
      flex-direction: column;
      align-items: start;
    }
  }

  @media (max-width: 767px) {
    .why-raluma__container {
      padding: 64px 18px;
    }

    .why-raluma__intro {
      margin-bottom: 22px;
    }

    .why-raluma__title {
      max-width: 11ch;
      font-size: clamp(34px, 10vw, 48px);
      line-height: 0.97;
    }

    .why-raluma__lead {
      max-width: none;
      font-size: 16px;
      line-height: 1.62;
    }

    .why-raluma__grid {
      grid-template-columns: 1fr;
      gap: 12px;
    }

    .proof-card,
    .proof-card--featured {
      padding: 20px 18px;
      border-radius: 22px;
    }

    .proof-card::before,
    .proof-card--featured::before {
      top: 18px;
      bottom: 18px;
    }

    .proof-card__title,
    .proof-card--featured .proof-card__title {
      font-size: 26px;
      max-width: none;
    }

    .proof-card__text {
      font-size: 14px;
      line-height: 1.62;
    }

    .why-raluma__footer {
      margin-top: 12px;
      padding: 18px;
      border-radius: 22px;
    }

    .why-raluma__footer-title {
      font-size: 22px;
    }

    .why-raluma__footer-text {
      font-size: 14px;
      line-height: 1.58;
    }

    .why-raluma__cta {
      width: 100%;
    }
  }
</style>
