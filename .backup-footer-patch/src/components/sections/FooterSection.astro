---
const phone = '+7 (812) 330-74-15';
const phoneHref = 'tel:+78123307415';
const address = 'Санкт-Петербург, Ленинский пр-т, д. 55, корп. 2';
const hours = 'Ежедневно 9:00–21:00';
const email = 'hello@raluma.com.ru';
const ogrnip = '324784700069042';
const year = new Date().getFullYear();
---

<footer class="site-footer" aria-label="Подвал сайта">
  <div class="site-footer__wrap">

    <div class="site-footer__top">
      <div class="site-footer__brand">
        <p class="site-footer__logo">Raluma</p>
        <p class="site-footer__tagline">
          Безрамное остекление<br />в Санкт-Петербурге и области
        </p>
      </div>

      <div class="site-footer__contacts">
        <a class="site-footer__phone" href={phoneHref}>{phone}</a>
        <p class="site-footer__hours">{hours}</p>
        <p class="site-footer__address">{address}</p>
        <a class="site-footer__email" href={`mailto:${email}`}>{email}</a>
      </div>

      <div class="site-footer__action">
        <a class="site-footer__cta" href="#lead-form">Получить расчёт</a>
      </div>
    </div>

    <div class="site-footer__bottom">
      <p class="site-footer__legal">
        ОГРНИП {ogrnip}&nbsp;·&nbsp;© {year} Raluma
      </p>
      <p class="site-footer__note">
        Производство и монтаж безрамных систем
      </p>
    </div>

  </div>
</footer>

<style>
  .site-footer {
    background: linear-gradient(180deg, #0d1016 0%, #0a0d12 100%);
    color: rgba(255, 255, 255, 0.88);
  }

  .site-footer__wrap {
    max-width: 1280px;
    margin: 0 auto;
    padding: clamp(52px, 6vw, 80px) 24px clamp(28px, 3.5vw, 44px);
  }

  /* ── Top row ── */
  .site-footer__top {
    display: grid;
    grid-template-columns: minmax(0, 1.4fr) minmax(0, 1fr) auto;
    gap: 40px;
    align-items: start;
    padding-bottom: clamp(28px, 3.5vw, 44px);
    border-bottom: 1px solid rgba(255, 255, 255, 0.08);
  }

  /* ── Brand ── */
  .site-footer__logo {
    margin: 0 0 10px;
    font-size: 26px;
    font-weight: 800;
    letter-spacing: -0.04em;
    color: #ffffff;
    line-height: 1;
  }

  .site-footer__tagline {
    margin: 0;
    font-size: 15px;
    line-height: 1.55;
    color: rgba(255, 255, 255, 0.48);
  }

  /* ── Contacts ── */
  .site-footer__contacts {
    display: flex;
    flex-direction: column;
    gap: 9px;
  }

  .site-footer__phone {
    display: inline-block;
    font-size: 22px;
    font-weight: 700;
    letter-spacing: -0.03em;
    color: #ffffff;
    text-decoration: none;
    line-height: 1.1;
    transition: color 0.2s ease;
  }

  .site-footer__phone:hover {
    color: #ff6b5d;
  }

  .site-footer__hours,
  .site-footer__address {
    margin: 0;
    font-size: 14px;
    line-height: 1.5;
    color: rgba(255, 255, 255, 0.48);
  }

  .site-footer__email {
    font-size: 14px;
    color: rgba(255, 255, 255, 0.48);
    text-decoration: underline;
    text-underline-offset: 3px;
    transition: color 0.2s ease;
  }

  .site-footer__email:hover {
    color: rgba(255, 255, 255, 0.76);
  }

  /* ── CTA ── */
  .site-footer__action {
    padding-top: 3px;
  }

  .site-footer__cta {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 48px;
    padding: 0 22px;
    border-radius: 999px;
    background: #e44336;
    color: #ffffff;
    font-size: 14px;
    font-weight: 700;
    text-decoration: none;
    white-space: nowrap;
    transition:
      background 0.22s ease,
      transform 0.22s ease,
      box-shadow 0.22s ease;
  }

  .site-footer__cta:hover {
    background: #d73a2e;
    transform: translateY(-1px);
    box-shadow: 0 12px 28px rgba(228, 67, 54, 0.28);
  }

  /* ── Bottom row ── */
  .site-footer__bottom {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
    flex-wrap: wrap;
    padding-top: clamp(18px, 2.5vw, 26px);
  }

  .site-footer__legal,
  .site-footer__note {
    margin: 0;
    font-size: 13px;
    line-height: 1.5;
    color: rgba(255, 255, 255, 0.28);
  }

  /* ── Responsive ── */
  @media (max-width: 900px) {
    .site-footer__top {
      grid-template-columns: 1fr 1fr;
    }

    .site-footer__brand {
      grid-column: 1 / -1;
    }

    .site-footer__action {
      grid-column: 1 / -1;
      padding-top: 0;
    }
  }

  @media (max-width: 600px) {
    .site-footer__wrap {
      padding: 44px 18px 28px;
    }

    .site-footer__top {
      grid-template-columns: 1fr;
      gap: 24px;
    }

    .site-footer__brand {
      grid-column: 1;
    }

    .site-footer__action {
      grid-column: 1;
    }

    .site-footer__cta {
      width: 100%;
      justify-content: center;
    }

    .site-footer__bottom {
      flex-direction: column;
      align-items: flex-start;
      gap: 8px;
    }
  }
</style>
